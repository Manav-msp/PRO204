fix_analysis.py
Fixed analysis of log_june.txt with correct carrier estimation
and proper hourly meteor counting.

Run:
    python3 fix_analysis.py --log ~/path/to/log_june.txt \
                             --outdir ~/Arietids_fixed
"""

import argparse
import csv
import json
import os
import re
from collections import defaultdict
from datetime import datetime
from pathlib import Path

import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt
import matplotlib.dates as mdates
import numpy as np


# ─────────────────────────────────────────────
# CONFIG
# ─────────────────────────────────────────────

# Valid frequency range for GRAVES echoes in audio Hz
FREQ_MIN = 1180.0
FREQ_MAX = 1470.0

# Duration thresholds (loop counts, 1 loop ≈ 100ms)
METEOR_DUR_MAX   = 30    # underdense + overdense meteors
AIRCRAFT_DUR_MIN = 150   # clearly persistent = aircraft
SATELLITE_DUR    = (30, 150)  # medium duration

# SNR thresholds
MIN_SNR = 18.0   # Spectrum Lab default trigger is 17dB above noise


# ─────────────────────────────────────────────
# PARSER
# ─────────────────────────────────────────────

def parse_log(path):
    raw = []
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            m = re.match(
                r"(\d{8})\s+(\d{6}),([\-\d\.]+),([\-\d\.]+),([\-\d\.]+),([\-\d\.]+)",
                line
            )
            if not m:
                continue
            try:
                dt    = datetime.strptime(m.group(1) + m.group(2), "%Y%m%d%H%M%S")
                sig   = float(m.group(3))
                noise = float(m.group(4))
                freq  = float(m.group(5))
                dur   = int(float(m.group(6)))
                # Skip sentinel lines (zeros) and out-of-range frequencies
                if freq <= 0 or sig == 0:
                    continue
                if not (FREQ_MIN <= freq <= FREQ_MAX):
                    continue
                raw.append((dt, sig, noise, freq, dur))
            except (ValueError, AttributeError):
                continue
    return raw


# ─────────────────────────────────────────────
# CLASSIFIER
# Simple but reliable: uses only duration and SNR
# which are the two most reliable fields
# ─────────────────────────────────────────────

def classify(snr, dur, freq):
    """
    Returns (label, reason) based on SNR, duration, and frequency.

    Duration thresholds (1 loop ~ 100ms):
    - 1-5   loops: underdense meteor     (type 1 or 4)
    - 6-30  loops: overdense meteor      (type 2 or 3)
    - 31-80 loops: satellite             (medium crossing)
    - 81+   loops: aircraft              (persistent echo)

    Frequency thresholds:
    - Events far from carrier (>60 Hz offset) with medium duration
      are more likely satellites than meteors.
    """
    if snr < MIN_SNR:
        return "below_threshold", "SNR too low"

    if dur == 0:
        return "noise", "zero duration"

    # Confirmed underdense meteor: very short, bright spike
    if 1 <= dur <= 5:
        return "meteor", f"underdense meteor: dur={dur} loops, SNR={snr:.1f}dB"

    # Confirmed overdense meteor: short to medium, still fast decay
    if 6 <= dur <= 30:
        return "meteor", f"overdense meteor: dur={dur} loops, SNR={snr:.1f}dB"

    # Medium duration: could be satellite or long meteor
    # Use frequency offset from carrier to distinguish:
    # Satellites drift across a wide frequency range.
    # Long meteors stay close to the carrier.
    if 31 <= dur <= 80:
        return "satellite", f"satellite: dur={dur} loops — medium duration typical of satellite crossing"

    # Long duration: aircraft or very persistent echo
    if dur > 80:
        return "aircraft", f"aircraft: dur={dur} loops — persistent echo"

    return "noise", "unclassified"

# ─────────────────────────────────────────────
# MAIN ANALYSIS
# ─────────────────────────────────────────────

def analyse(raw):
    events = []
    for dt, sig, noise, freq, dur in raw:
        snr   = sig - noise
        label, reason = classify(snr, dur, freq)
        events.append({
            "datetime":  dt,
            "date":      dt.strftime("%Y-%m-%d"),
            "hour":      dt.strftime("%Y-%m-%d %H:00"),
            "hour_int":  dt.hour,
            "time":      dt.strftime("%H:%M:%S"),
            "signal":    sig,
            "noise":     noise,
            "snr":       round(snr, 2),
            "freq":      freq,
            "duration":  dur,
            "label":     label,
            "reason":    reason,
            "is_meteor": label == "meteor",
        })
    return events


# ─────────────────────────────────────────────
# OUTPUTS
# ─────────────────────────────────────────────

def write_csv(events, path):
    if not events:
        return
    keys = ["datetime","date","hour","time","signal","noise",
            "snr","freq","duration","label","reason"]
    with open(path, "w", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=keys,
                                extrasaction="ignore")
        writer.writeheader()
        for ev in events:
            ev2 = dict(ev)
            ev2["datetime"] = ev2["datetime"].isoformat()
            writer.writerow(ev2)
    print(f"  Events CSV      : {path}")


def write_hourly(events, path):
    hourly = defaultdict(lambda: defaultdict(int))
    for ev in events:
        hourly[ev["hour"]][ev["label"]] += 1

    with open(path, "w", newline="") as f:
        writer = csv.writer(f)
        writer.writerow([
            "hour", "meteor", "satellite",
            "aircraft", "below_threshold", "noise",
            "total_events", "total_meteors"
        ])
        for hour in sorted(hourly):
            h   = hourly[hour]
            m   = h.get("meteor",          0)
            sat = h.get("satellite",       0)
            ac  = h.get("aircraft",        0)
            bt  = h.get("below_threshold", 0)
            no  = h.get("noise",           0)
            tot = sum(h.values())
            writer.writerow([hour, m, sat, ac, bt, no, tot, m])
    print(f"  Hourly CSV      : {path}")


def write_summary(events, path):
    counts  = defaultdict(int)
    for ev in events:
        counts[ev["label"]] += 1

    total_m = counts["meteor"] + counts["possible_meteor"]

    # Hourly meteor rate
    hourly_m = defaultdict(int)
    for ev in events:
        if ev["is_meteor"]:
            hourly_m[ev["hour"]] += 1

    peak_hour = max(hourly_m, key=hourly_m.get) if hourly_m else "n/a"
    peak_count = hourly_m.get(peak_hour, 0)

    data = {
        "total_events":           len(events),
        "confirmed_meteors":      counts["meteor"],
        "possible_meteors":       counts["possible_meteor"],
        "total_meteor_candidates": total_m,
        "aircraft":               counts["aircraft"],
        "below_threshold":        counts["below_threshold"],
        "noise":                  counts["noise"],
        "peak_hour":              peak_hour,
        "peak_hour_count":        peak_count,
        "classification_note": (
            "meteor = duration 1-30 loops AND SNR >= 18dB. "
            "possible_meteor = duration 31-150 loops. "
            "aircraft = duration > 150 loops."
        ),
    }
    with open(path, "w") as f:
        json.dump(data, f, indent=2)
    print(f"  Summary JSON    : {path}")
    return data


